{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "es6",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "sourceMap": true,
    "declaration": true,
    "types": ["node", "jest"],
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}